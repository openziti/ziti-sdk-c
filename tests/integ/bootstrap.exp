#!expect

set timeout 600
proc abort errs {
    puts "test failed: $errs"
    exit 2
}
set ziti $env(ZITI_CLI)
puts "ziti = $ziti"

set enroller $env(ENROLLER)
puts "enroller = $env(ENROLLER)"

puts "Starting Ziti Quickstart"
puts "========================"

spawn $ziti edge quickstart --home $env(QUICKSTART_HOME) --ctrl-address=127.0.0.1 --router-address=127.0.0.1
set qs_id @spawn_id
# wait until ER is connected
expect {
    "controller and router started" { }
    timeout { error "qs not started in time" }
    eof { error "qs not started" }
}

puts "Configure model"
puts "==============="
log_user 1

expect_before {
   timeout { abort "timeout" }
   "connection refused" { abort "QS not started" }
}

spawn $ziti edge create identity test-client -a client -o $env(QUICKSTART_HOME)/test-client.jwt
expect {
     "New identity test-client created" {}
     "error" { abort $expect_out(buffer) }
     eof { abort "unexpected" }
}

spawn $ziti edge create identity test-server -a server -o $env(QUICKSTART_HOME)/test-server.jwt
expect {
    "New identity test-server created" {}
    "error" { error $expect_out(buffer) }
}

spawn $ziti edge create service test-service
expect {
     "New service test-service created" { }
     -re "error(.*)" { error $expect_out(1,string) }
     eof { error "not cool" }
}

spawn $ziti edge create service-policy servers-bind Bind --identity-roles \#server --service-roles \#all
expect {
    "New service policy servers-bind created" {}
    -re "error(.*)" { error $expect_out(1,string) }
    eof { error "not cool" }
}

spawn $ziti edge create service-policy clients-dial Dial --identity-roles \#client --service-roles \#all
expect {
    "New service policy clients-dial created" {}
    -re "error(.*)" { error $expect_out(1,string) }
    eof { error "not cool" }
}

puts "Setting up Keycloak (optional)"
puts "=============================="

set keycloak_available 0
if {[info exists env(BOOTSTRAP_DIR)]} {
    spawn sh -c "QUICKSTART_HOME=$env(QUICKSTART_HOME) $env(BOOTSTRAP_DIR)/setup-keycloak.sh"
    expect {
        "Keycloak setup complete" { set keycloak_available 1 }
        "Failed" { puts "WARNING: Keycloak setup failed, lifecycle tests will be skipped" }
        timeout { puts "WARNING: Keycloak setup timed out, lifecycle tests will be skipped" }
        eof { puts "WARNING: Keycloak setup failed, lifecycle tests will be skipped" }
    }
    catch { wait }
} else {
    puts "WARNING: BOOTSTRAP_DIR not set, skipping Keycloak setup"
}

puts "Setting up ext-jwt-signers for enrollment tests"
puts "================================================"

spawn openssl genrsa -out $env(QUICKSTART_HOME)/test-jwt-signer.key 2048
expect eof
wait

spawn openssl req -new -x509 -key $env(QUICKSTART_HOME)/test-jwt-signer.key -out $env(QUICKSTART_HOME)/test-jwt-signer.crt -days 365 -subj "/CN=test-jwt-signer/O=OpenZiti Test"
expect eof
wait

set kid [exec sh -c "openssl x509 -in $env(QUICKSTART_HOME)/test-jwt-signer.crt -outform DER | shasum -a 1 | awk '{print \$1}'"]
exec sh -c "echo $kid > $env(QUICKSTART_HOME)/test-jwt-signer.kid"

# cert-file signer for enrollToCert (existing tests)
spawn $ziti edge create ext-jwt-signer test-ext-jwt-signer "https://test-jwt-issuer.example.com" --cert-file $env(QUICKSTART_HOME)/test-jwt-signer.crt --audience openziti --enroll-to-cert --kid $kid
expect {
    -re "New ext-jwt-signer .* created" {}
    -re "\[a-zA-Z0-9\]+" {}
    "error" { abort $expect_out(buffer) }
    eof { abort "ext-jwt-signer not created" }
}

# cert-file signer for enrollToToken (distinct issuer, same key/cert/kid)
spawn $ziti edge create ext-jwt-signer test-ext-jwt-signer-token "https://test-jwt-issuer-token.example.com" --cert-file $env(QUICKSTART_HOME)/test-jwt-signer.crt --audience openziti --enroll-to-token --kid $kid
expect {
    -re "New ext-jwt-signer .* created" {}
    -re "\[a-zA-Z0-9\]+" {}
    "error" { abort $expect_out(buffer) }
    eof { abort "ext-jwt-signer-token not created" }
}

# write marker so tests know if Keycloak is available
exec sh -c "echo $keycloak_available > $env(QUICKSTART_HOME)/keycloak-available"

if {$keycloak_available} {
    # OIDC signer using Keycloak (for lifecycle tests)
    spawn $ziti edge create ext-jwt-signer test-oidc-signer "http://localhost:8080/realms/ziti-test" --jwks-endpoint "http://localhost:8080/realms/ziti-test/protocol/openid-connect/certs" --external-auth-url "http://localhost:8080/realms/ziti-test" --client-id ziti-enrolltocert --audience account --enroll-to-cert --enroll-to-token
    expect {
        -re "New ext-jwt-signer .* created" {}
        -re "\[a-zA-Z0-9\]+" {}
        "error" { abort $expect_out(buffer) }
        eof { abort "oidc signer not created" }
    }
}

# pre-created identity for enroll-none tests
spawn $ziti edge create identity test-precreated -a client
expect {
    "New identity test-precreated created" {}
    "error" { abort $expect_out(buffer) }
    eof { abort "test-precreated not created" }
}

puts "Enrolling test identities"
puts "========================="

spawn $enroller $env(QUICKSTART_HOME)/test-server.jwt $env(QUICKSTART_HOME)/test-server.json
expect {
    "ziti identity is saved" {}
    eof { error "test-server not enrolled" }
}
wait

spawn $enroller $env(QUICKSTART_HOME)/test-client.jwt $env(QUICKSTART_HOME)/test-client.json
expect {
    "ziti identity is saved" {}
    eof { error "test-client not enrolled" }
}
wait
